# PostgreSQL
DB_USERNAME=climatebus
DB_PASSWORD=your_password_here

# 서울 열린데이터광장 버스 공공 API
# 발급: https://data.seoul.go.kr
SEOUL_BUS_API_KEY=your_api_key

# T-Map API (SK Open API)
# 발급: https://openapi.sk.com
TMAP_API_KEY=your_api_key

# JWT 서명 비밀키 (최소 32자 이상 랜덤 문자열)
JWT_SECRET=your_jwt_secret_at_least_32_chars
